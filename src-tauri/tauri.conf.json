{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tiny-whisper",
  "version": "0.1.0",
  "identifier": "dev.tinywhisper.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tiny-whisper — settings",
        "width": 560,
        "height": 640,
        "resizable": true,
        "visible": false,
        "label": "settings"
      },
      {
        "label": "indicator",
        "url": "indicator.html",
        "width": 240,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "signCommand": "signtool sign /sha1 278AF2DF6531D16AE28C617248E3FF329C676BD9 /fd sha256 /tr http://timestamp.comodoca.com /td sha256 %1"
    }
  },
  "plugins": {}
}
